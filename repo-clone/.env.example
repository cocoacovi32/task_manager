# Django Settings
SECRET_KEY=django-insecure-change-this-to-random-key-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,*.vercel.app

# Database Configuration (PostgreSQL) - Railway will provide these
DATABASE_URL=postgresql://
DB_NAME=task_manager
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_HOST=db
DB_PORT=5432

# CORS Settings - Include your Vercel frontend domain
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.vercel.app

# API URL for Frontend (Vercel will inject this)
REACT_APP_API_URL=http://localhost:8000
